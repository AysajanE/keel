#!/usr/bin/env bash
# keel-compile — thin wrapper for the Keel gstack->playbook compiler.
#
# Self-resolves KEEL_ROOT from this script's location, so it works
# whether you sourced keel.env or invoked the wrapper by absolute path.
#
# Equivalent long form:
#   python "$KEEL_ROOT/tools/compiler/automation/run_gstack_compiler.py" "$@"

set -euo pipefail
KEEL_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KEEL_ROOT="$(cd "$KEEL_BIN_DIR/.." && pwd)"
KEEL_COMPILER_ROOT="$KEEL_ROOT/tools/compiler"
export KEEL_ROOT
if [ "${1:-}" = "--version" ]; then
  version="${KEEL_VERSION:-$(git -C "$KEEL_ROOT" describe --tags --always --dirty 2>/dev/null || echo unknown)}"
  echo "keel $version"
  exit 0
fi
if [ -x "$KEEL_COMPILER_ROOT/.venv/bin/python" ]; then
  PY="$KEEL_COMPILER_ROOT/.venv/bin/python"
else
  PY="${KEEL_PYTHON:-python3}"
fi
exec "$PY" "$KEEL_COMPILER_ROOT/automation/run_gstack_compiler.py" "$@"
