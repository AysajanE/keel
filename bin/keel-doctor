#!/usr/bin/env bash
# keel-doctor — diagnostic wrapper. Two modes:
#
#   keel-doctor --playbook <path>            # validate a playbook file (file-only)
#   keel-doctor --run-id <RUN_ID> [--format json]  # diagnose a live PO run
#
# This is a focused shortcut for `keel-run doctor "$@"` with one nicety:
# when only `--playbook` is provided (no `--run-id`), the wrapper sets
# PLAN_ORCHESTRATOR_CLEAN_ENV_CONFIRMED=1 so PO's agent_environment check
# is treated as acknowledged. Playbook-only validation never executes code,
# so the ambient-agent warning is operationally irrelevant in that mode.
# For any --run-id call, the wrapper leaves the env alone and you must
# acknowledge the agent environment yourself.

set -euo pipefail
KEEL_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
KEEL_ROOT="$(cd "$KEEL_BIN_DIR/.." && pwd)"

if [ "${1:-}" = "--version" ]; then
  version="${KEEL_VERSION:-$(git -C "$KEEL_ROOT" describe --tags --always --dirty 2>/dev/null || echo unknown)}"
  echo "keel $version"
  exit 0
fi

if [ "$#" -lt 1 ]; then
  echo "usage: keel-doctor --playbook <path> OR --run-id <ID> [--format text|json]" >&2
  exit 2
fi

has_playbook=0
has_run_id=0
for arg in "$@"; do
  case "$arg" in
    --playbook|--playbook=*) has_playbook=1 ;;
    --run-id|--run-id=*)     has_run_id=1   ;;
  esac
done

if [ "$has_playbook" = "1" ] && [ "$has_run_id" = "0" ]; then
  export PLAN_ORCHESTRATOR_CLEAN_ENV_CONFIRMED="${PLAN_ORCHESTRATOR_CLEAN_ENV_CONFIRMED:-1}"
fi

exec "$KEEL_BIN_DIR/keel-run" doctor "$@"
